{
  "family": "hr-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::469049066557:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::469049066557:role/ecsTaskRole-email",
  "containerDefinitions": [
    {
      "name": "hr-backend",
      "image": "469049066557.dkr.ecr.ap-south-1.amazonaws.com/cpb/hr-management-backend:58dc0f4d897f9ed00810bb24f8f8727b541c7a07",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3001,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "PORT", "value": "3001" },
        { "name": "NODE_ENV", "value": "production" },
        { "name": "AWS_REGION", "value": "ap-south-1" },
        { "name": "DATABASE_URL", "value": "postgresql://neondb_owner:npg_yt0DUZTKMIz4@ep-mute-firefly-a1qb4w5s-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require" },
        { "name": "JWT_SECRET", "value": "26c74a9effd32d30d439d85b0f3360c42318a9c20b622d595a3fc2935ed4c5a1433e1df1c6d17341ede8bb44194f3098b5178909250748f19f8325ea3fbc734e" },
        { "name": "JWT_EXPIRATION", "value": "7d" },
        { "name": "EMAIL_PROVIDER", "value": "ses" },
        { "name": "EMAIL_FROM", "value": "techcareerplanb@gmail.com" },
        { "name": "FRONTEND_URL", "value": "https://cpb-hr.vercel.app" },
        { "name": "FILE_UPLOAD_PATH", "value": "./uploads" },
        { "name": "MAX_FILE_SIZE", "value": "5242880" },
        { "name": "STORAGE_PROVIDER", "value": "s3" },
        { "name": "S3_REGION", "value": "ap-south-1" },
        { "name": "S3_BUCKET", "value": "cpb-hr-files" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/hr-backend",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:3001/api/health || exit 1"],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 120
      }
    }
  ]
}
